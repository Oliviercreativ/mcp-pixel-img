# URL de ton instance pixel-img (Vercel ou local)
PIXEL_IMG_URL=https://pixel-img.vercel.app

# Ton API_PASSWORD pixel-img
PIXEL_IMG_API_KEY=your_api_password_here

# Optionnel — si tu utilises les webhooks Airtable
PIXEL_IMG_WEBHOOK_SECRET=

# Secret pour protéger le endpoint SSE (recommandé en prod)
MCP_SECRET=your_mcp_secret_here

# Port d'écoute (défaut: 3001)
PORT=3001
